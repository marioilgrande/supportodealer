# Copia questo file in .env.local (sviluppo) e imposta gli stessi valori
# nelle Environment Variables di Vercel (Production + Preview + Development).

# --- Database Neon (progetto supporto-dealer) ---
DATABASE_URL="postgresql://...neon.tech/...?sslmode=require"

# --- Database Neon del PANNELLO SEGNALAZIONI (per leggere i negozi -> SIS/SUB) ---
# Cosi' i negozi si gestiscono solo li' e valgono subito anche qui, senza deploy.
# Se manca, l'app usa l'elenco statico di fallback in lib/negozi.js.
SEGNALAZIONI_DATABASE_URL="postgresql://...neon.tech/...?sslmode=require"

# --- Login dashboard (admin = Mario, backup = Simone) ---
AUTH_EMAIL="mario.isernia@e2kdistribution.com"
AUTH_PASSWORD="scegli-una-password"
AUTH_EMAIL_SIMONE="simone.censi@e2kdistribution.com"
AUTH_PASSWORD_SIMONE="scegli-una-password-per-simone"
# Stringa random >= 32 caratteri: genera con  openssl rand -base64 48
SESSION_SECRET="..."

# --- Intelligenza artificiale (Google Gemini) ---
# Chiave gratuita da https://aistudio.google.com/apikey
GEMINI_API_KEY="..."

# --- Email (Gmail via SMTP) ---
# Consegna affidabile (niente spam), nessun DNS. Serve un account Gmail con
# verifica in 2 passaggi attiva + una "Password per le app" (16 caratteri):
# https://myaccount.google.com/apppasswords
GMAIL_USER="tuoindirizzo@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
MAIL_FROM_NAME="Supporto Dealer"
# Destinatari delle notifiche
MAIL_ADMIN="mario.isernia@e2kdistribution.com"
MAIL_SIMONE="simone.censi@e2kdistribution.com"
